      "model": "o4-mini",
      "permission_mode": "default",
      "prompt": "What files are in this directory?",
      "transcript_path": "__transcript_path__"
    }
  },
  "Stop": {
    "coverage": "verified",
    "payload": {
      "session_id": "__session_id__",
      "cwd": "__cwd__",
      "hook_event_name": "Stop",
      "model": "o4-mini",
      "permission_mode": "default",
      "transcript_path": "__transcript_path__"
    }
  }
