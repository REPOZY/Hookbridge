{
  "SessionStart": {
    "coverage": "verified",
    "payload": {
      "session_id": "__session_id__",
      "cwd": "__cwd__",
      "hook_event_name": "SessionStart",
      "model": "o4-mini",
      "permission_mode": "default",
      "source": "startup",
      "transcript_path": "__transcript_path__"
    }
  },
  "PreToolUse": {
    "coverage": "verified",
    "payload": {
      "session_id": "__session_id__",
      "turn_id": "turn_001",
      "cwd": "__cwd__",
      "hook_event_name": "PreToolUse",
      "model": "o4-mini",
      "permission_mode": "default",
      "tool_name": "__tool_name__",
      "tool_use_id": "call_abc123",
      "tool_input": { "command": "ls -la" },
      "transcript_path": "__transcript_path__"
    }
  },
  "PostToolUse": {
    "coverage": "verified",
    "payload": {
      "session_id": "__session_id__",
      "turn_id": "turn_001",
      "cwd": "__cwd__",
      "hook_event_name": "PostToolUse",
      "model": "o4-mini",
      "permission_mode": "default",
      "tool_name": "__tool_name__",
      "tool_use_id": "call_abc123",
      "tool_input": { "command": "ls -la" },
      "tool_response": "file1.txt\nfile2.txt",
      "transcript_path": "__transcript_path__"
    }
  },
  "UserPromptSubmit": {
    "coverage": "verified",
    "payload": {
      "session_id": "__session_id__",
      "turn_id": "turn_001",
      "cwd": "__cwd__",
